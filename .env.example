NCBI_API_KEY=
NCBI_EMAIL=
NCBI_TOOL=EzResearch
OPENALEX_MAILTO=

# Optional expert-agent synthesis for richer briefs/decks.
# Enable and require this when you want the research-agent layer to run on every request.
OPENAI_API_KEY=
OPENAI_RESEARCH_MODEL=gpt-4.1-mini
OPENAI_EXPERT_TIMEOUT_MS=25000
EZRESEARCH_ENABLE_EXPERT_SYNTHESIS=false
EZRESEARCH_REQUIRE_EXPERT_SYNTHESIS=false

# Keep demo mode available when public APIs fail.
# Set to false for strict live-data-only runs.
EZRESEARCH_ENABLE_MOCK_FALLBACK=true
