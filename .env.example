NCBI_API_KEY=
NCBI_EMAIL=
NCBI_TOOL=EzResearch
OPENALEX_MAILTO=

# Optional expert-agent synthesis for richer, presentation-ready briefs/decks.
# Requires OPENAI_API_KEY in .env.local. Set to false to force deterministic synthesis.
OPENAI_RESEARCH_MODEL=gpt-4.1
EZRESEARCH_ENABLE_EXPERT_SYNTHESIS=true

# Keep demo mode available when public APIs fail.
# Set to false for strict live-data-only runs.
EZRESEARCH_ENABLE_MOCK_FALLBACK=true
